{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=invites_blog;Username=invites;Password=invites_password"
  },
  "Jwt": {
    "Issuer": "invites.blog",
    "Audience": "invites.blog",
    "SigningKey": "dev-only-signing-key-change-me-to-a-long-random-value-0123456789"
  },
  "Storage": {
    "Provider": "Local",
    "Bucket": "invites-assets",
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minio",
    "SecretKey": "minio_password"
  },
  "Email": {
    "Provider": "Console",
    "ApiKey": "",
    "From_Invites": "invites.blog <invites@mail.invites.blog>",
    "From_System": "invites.blog <no-reply@mail.invites.blog>",
    "WebhookSecret": ""
  },
  "Payments": { "Provider": "Fake", "WebhookSecret": "fake-webhook-secret" },
  "Otp": { "Channels": "Email", "ExpiryMinutes": 5 },
  "Privacy": { "DefaultRetentionDays": 90 },
  "Urls": {
    "ApiBase": "http://localhost:8080",
    "InviterBase": "http://localhost:4200",
    "InviteeBase": "http://localhost:4201",
    "AssetsBase": "http://localhost:8080/assets"
  }
}
